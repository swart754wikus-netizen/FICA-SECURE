# Firebase Admin SDK service account (Firebase Console → Project settings →
# Service accounts → Generate new private key). Set these as Vercel
# environment variables — never commit the real values.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com

# Must exactly match the one Firebase Auth account allowed to use the super
# admin portal, and the email hardcoded into firestore.rules / storage.rules.
SUPER_ADMIN_EMAIL=
