# Firebase Admin SDK service account (Firebase Console → Project settings →
# Service accounts → Generate new private key, project fica-app-fc93c). Set
# these as Vercel environment variables — never commit the real values.
FIREBASE_PROJECT_ID=fica-app-fc93c
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
FIREBASE_STORAGE_BUCKET=fica-app-fc93c.firebasestorage.app

# Must exactly match the one Firebase Auth account allowed to use the super
# admin portal, and the email hardcoded into firestore.rules / storage.rules.
SUPER_ADMIN_EMAIL=swart754wikus@gmail.com
